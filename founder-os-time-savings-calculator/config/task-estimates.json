    "email_triage": {
      "plugin": "P01 Inbox Zero Commander",
      "notion_db": "[FOS] Tasks",
      "notion_db_legacy": "Founder OS HQ - Tasks",
      "type_filter": "Email Task",
      "date_property": "Created At",
      "count_filter": { "property": "Status", "values": ["Done", "Archived"] },
      "manual_minutes": 120,
      "ai_minutes": 15,
      "unit": "per batch",
      "description": "Email triage, priority scoring, and action extraction"
    },
